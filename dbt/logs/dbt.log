[0m16:50:37.104877 [debug] [Thread-1 (]: On model.market_intelligence.stg_daily_market: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "market_intelligence", "target_name": "dev", "node_id": "model.market_intelligence.stg_daily_market"} */

  
  create view "market_intelligence"."analytics"."stg_daily_market__dbt_tmp" as (
    /*
  STAGING: stg_daily_market
  --------------------------
  Clean read from Gold layer with:
  - NULL sentiment defaulted to 'neutral' (0.5)
  - NULL macro indicators forward-filled or defaulted
  - Consistent column naming
*/

with source as (
    select * from "market_intelligence"."gold"."fct_daily_market_summary"
),

cleaned as (
    select
        date,
        ticker,

        -- Price data (always present)
        open,
        high,
        low,
        close,
        volume,
        daily_return,
        price_range,

        -- Sentiment (default to neutral when no news data)
        coalesce(news_article_count, 0) as news_article_count,
        coalesce(avg_sentiment_score, 0.5) as sentiment_score,
        coalesce(positive_news_count, 0) as positive_news_count,
        coalesce(negative_news_count, 0) as negative_news_count,
        coalesce(neutral_news_count, 0) as neutral_news_count,
        coalesce(positive_sentiment_ratio, 0.5) as positive_sentiment_ratio,

        -- Flag: do we have real sentiment data for this day?
        case
            when avg_sentiment_score is not null then true
            else false
        end as has_sentiment_data,

        -- Macro indicators
        federal_funds_rate,
        vix_volatility_index,
        treasury_yield_spread,
        consumer_price_index,
        unemployment_rate,

        -- Derived features
        rolling_7d_avg_close,
        rolling_7d_avg_volume,
        rolling_7d_avg_sentiment,
        overnight_gap_pct,
        price_vs_7d_avg_pct,
        volume_spike_ratio,

        -- Metadata
        source,
        ingested_at

    from source
)

select * from cleaned
  );

