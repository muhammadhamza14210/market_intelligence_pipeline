[0m16:50:37.174545 [debug] [Thread-1 (]: On model.market_intelligence.fct_market_signals: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "market_intelligence", "target_name": "dev", "node_id": "model.market_intelligence.fct_market_signals"} */

  
  create view "market_intelligence"."analytics"."fct_market_signals__dbt_tmp" as (
    /*
  MART: fct_market_signals
  -------------------------
  Adds business logic on top of staging:
  - Market signal classification (bullish/bearish/neutral)
  - Unusual activity flags
  - Risk indicators

  This is where raw data becomes business insight.
  Each CASE statement is a business decision you can explain in interviews.
*/

with daily as (
    select * from "market_intelligence"."analytics"."stg_daily_market"
),

with_signals as (
    select
        date,
        ticker,
        close,
        daily_return,
        volume,
        sentiment_score,
        has_sentiment_data,
        news_article_count,
        federal_funds_rate,
        vix_volatility_index,
        rolling_7d_avg_close,
        volume_spike_ratio,
        price_vs_7d_avg_pct,
        overnight_gap_pct,

        -- === MARKET SIGNAL ===
        -- Combines price action + sentiment into a single classification
        case
            when has_sentiment_data = true
                 and daily_return > 1.0
                 and sentiment_score > 0.6
                then 'strong_bullish'
            when has_sentiment_data = true
                 and daily_return < -1.0
                 and sentiment_score < 0.4
                then 'strong_bearish'
            when daily_return > 1.5
                then 'bullish'
            when daily_return < -1.5
                then 'bearish'
            when daily_return > 0.5
                then 'slightly_bullish'
            when daily_return < -0.5
                then 'slightly_bearish'
            else 'neutral'
        end as market_signal,

        -- === UNUSUAL VOLUME FLAG ===
        -- Volume spike > 2x the 7-day average = something is happening
        case
            when volume_spike_ratio > 2.0 then 'high_volume_spike'
            when volume_spike_ratio > 1.5 then 'elevated_volume'
            when volume_spike_ratio < 0.5 then 'low_volume'
            else 'normal_volume'
        end as volume_signal,

        -- === TREND POSITION ===
        -- Is the stock trading above or below its 7-day average?
        case
            when price_vs_7d_avg_pct > 3.0 then 'well_above_trend'
            when price_vs_7d_avg_pct > 1.0 then 'above_trend'
            when price_vs_7d_avg_pct < -3.0 then 'well_below_trend'
            when price_vs_7d_avg_pct < -1.0 then 'below_trend'
            else 'at_trend'
        end as trend_position,

        -- === VIX RISK LEVEL ===
        -- VIX > 30 = high fear, < 15 = complacency
        case
            when vix_volatility_index > 30 then 'high_fear'
            when vix_volatility_index > 20 then 'elevated_anxiety'
            when vix_volatility_index > 15 then 'normal'
            when vix_volatility_index is not null then 'low_fear'
            else 'unknown'
        end as vix_risk_level,

        -- === SENTIMENT-PRICE DIVERGENCE ===
        -- When sentiment and price move in opposite directions
        case
            when has_sentiment_data = true
                 and sentiment_score > 0.7
                 and daily_return < -1.0
                then 'negative_divergence'  -- good news but price drops (worrying)
            when has_sentiment_data = true
                 and sentiment_score < 0.3
                 and daily_return > 1.0
                then 'positive_divergence'  -- bad news but price rises (bullish signal)
            else 'aligned'
        end as sentiment_price_alignment,

        -- === OVERNIGHT GAP SIGNAL ===
        case
            when overnight_gap_pct > 2.0 then 'gap_up'
            when overnight_gap_pct < -2.0 then 'gap_down'
            else 'no_gap'
        end as gap_signal

    from daily
)

select * from with_signals
  );

